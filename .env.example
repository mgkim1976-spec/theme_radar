# world_monitor 환경변수 — .env로 복사하여 실제 값 입력
# .env는 .gitignore에 등록되어 commit되지 않음

# OpenAI (gpt-5.4-nano 추출용)
OPENAI_API_KEY=sk-proj-...

# Webshare Residential Proxy (YouTube 자막 다운로드용)
# rotating residential 권장 (kulfidag-rotate)
WEBSHARE_PROXY_URL=http://username-rotate:password@p.webshare.io:80

# KRX 인증 (pykrx로 한국 주식 데이터 가져올 때 — FinanceDataReader 대안)
# https://data.krx.co.kr 에서 가입 후 ID/PW
KRX_ID=your_krx_id
KRX_PW=your_krx_password
